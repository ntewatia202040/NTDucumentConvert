@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold text-primary">
            About AntiConvert
        </h1>

        <p class="lead text-muted">
            Fast, Secure and Free Online Document Conversion Tools
        </p>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body p-5">

            <h3>Who We Are</h3>

            <p>
                AntiConvert is a free online document conversion platform designed to make
                file conversion simple, fast, and secure. Whether you need to convert PDF
                to Word, Word to PDF, Merge PDF, Compress PDF, or other document formats,
                our goal is to provide reliable tools that work directly in your browser.
            </p>

            <hr />

            <h3>Our Mission</h3>

            <p>
                Our mission is to provide easy-to-use online tools that help students,
                professionals, businesses, and individuals manage documents without
                installing complicated software.
            </p>

            <hr />

            <h3>Why Choose AntiConvert?</h3>

            <div class="row mt-4">

                <div class="col-md-3 text-center mb-4">

                    <h1>⚡</h1>

                    <h5>Fast Conversion</h5>

                    <p>
                        Convert your documents in seconds.
                    </p>

                </div>

                <div class="col-md-3 text-center mb-4">

                    <h1>🔒</h1>

                    <h5>Secure</h5>

                    <p>
                        Your uploaded files are automatically removed after processing.
                    </p>

                </div>

                <div class="col-md-3 text-center mb-4">

                    <h1>☁</h1>

                    <h5>Cloud Based</h5>

                    <p>
                        No software installation required.
                    </p>

                </div>

                <div class="col-md-3 text-center mb-4">

                    <h1>🆓</h1>

                    <h5>Free Tools</h5>

                    <p>
                        Most of our tools are completely free to use.
                    </p>

                </div>

            </div>

            <hr />

            <h3>Supported Tools</h3>

            <ul>

                <li>PDF to Word</li>

                <li>Word to PDF</li>

                <li>Merge PDF</li>

                <li>Compress PDF</li>

                <li>PDF to PowerPoint</li>

                <li>PowerPoint to PDF</li>

                <li>PDF to Excel</li>

                <li>Excel to PDF</li>

                <li>Image to PDF</li>

                <li>PDF to Image</li>

            </ul>

            <hr />

            <h3>Privacy & Security</h3>

            <p>
                We respect your privacy. Uploaded files are processed securely and
                automatically deleted after a short period of time. We never permanently
                store your personal documents.
            </p>

            <hr />

            <h3>Contact Us</h3>

            <p>

                Have questions or suggestions?

                <br /><br />

                Email :
                <a href="mailto:support@anticonvert.in">
                    support@anticonvert.in
                </a>

                <br />

                Website :
                <a href="https://anticonvert.in">
                    https://anticonvert.in
                </a>

            </p>

        </div>

    </div>

</div>