@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="fw-bold text-primary">
            Privacy Policy
        </h1>

        <p class="lead text-muted">
            Your privacy is important to us.
        </p>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body p-5">

            <p>
                At <strong>AntiConvert</strong>, we respect your privacy and are committed
                to protecting your personal information. This Privacy Policy explains how
                we collect, use, and safeguard your information when you use our website.
            </p>

            <hr />

            <h3>1. Information We Collect</h3>

            <p>
                We may collect limited technical information such as browser type,
                operating system, device information, IP address, and website usage
                statistics to improve our services.
            </p>

            <p>
                When you upload files for conversion, those files are processed only for
                providing the requested service.
            </p>

            <hr />

            <h3>2. Uploaded Files</h3>

            <p>
                Files uploaded to AntiConvert are used only to perform the requested
                conversion.
            </p>

            <ul>
                <li>Files are not shared with third parties.</li>
                <li>Files are not permanently stored.</li>
                <li>Files are automatically deleted after processing.</li>
            </ul>

            <hr />

            <h3>3. Cookies</h3>

            <p>
                We may use cookies to improve website functionality, remember user
                preferences, and analyze website traffic.
            </p>

            <hr />

            <h3>4. Google Services</h3>

            <p>
                Our website may use Google Analytics and Google AdSense.
                These services may use cookies to provide analytics and personalized
                advertisements.
            </p>

            <p>
                You can learn more by visiting Google's Privacy Policy.
            </p>

            <hr />

            <h3>5. Third-Party Services</h3>

            <p>
                We may use trusted third-party services for analytics, hosting,
                security, and advertising. These providers have their own privacy
                policies.
            </p>

            <hr />

            <h3>6. Data Security</h3>

            <p>
                We implement reasonable technical and organizational measures to protect
                your uploaded files and personal information from unauthorized access.
            </p>

            <hr />

            <h3>7. Children's Privacy</h3>

            <p>
                Our services are not intended for children under 13 years of age.
                We do not knowingly collect personal information from children.
            </p>

            <hr />

            <h3>8. Changes to this Privacy Policy</h3>

            <p>
                We may update this Privacy Policy from time to time.
                Any changes will be posted on this page.
            </p>

            <hr />

            <h3>9. Contact Us</h3>

            <p>

                If you have any questions regarding this Privacy Policy, you may contact us.

            </p>

            <p>

                <strong>Email:</strong>
                support@anticonvert.in

            </p>

            <p>

                <strong>Website:</strong>
                https://anticonvert.in

            </p>

            <hr />

            <p class="text-muted mb-0">

                Last Updated:
                @DateTime.Now.ToString("dd MMMM yyyy")

            </p>

        </div>

    </div>

</div>