@using System.Data
<title>PDF to Word Converter Online Free - AntiConvert</title>

<meta name="description"
      content="Convert PDF to Word online free. Fast, secure and easy PDF to DOCX conversion with AntiConvert." />
<meta property="og:title" content="PDF to Word Converter Online Free - AntiConvert" />
<meta property="og:description" content="Convert PDF to Word online free." />
<meta property="og:url" content="https://anticonvert.in/Tools/PdfToWord" />
<meta property="og:type" content="website" />
<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">
    <div class="card shadow p-4" style="width:500px;">
        <h2 class="text-center mb-3">@ViewBag.Type</h2>
    
        <p class="text-center text-muted">
            Upload your file and convert it.
        </p>

        @using (Html.BeginForm("AllConveter", "Tools", FormMethod.Post,
            new { enctype = "multipart/form-data" }))
        {
            <div class="mb-3">
                <label class="form-label">Select File</label>
                <input type="file" name="file" class="form-control" />
            </div>

            <input type="hidden" name="ConversionType" value="@ViewBag.Type" />

            <div class="text-center">
                <button type="submit" class="btn btn-primary">
                    Convert
                </button>
            </div>
        }
    </div>
</div>